<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professional Resume Builder</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header>
        <h1>Resume Builder Portal</h1>
    </header>

    <main class="container">
        <section class="editor">
            <h2>Personal Details</h2>
            <div class="input-group">
                <label>Full Name</label>
                <input type="text" placeholder="e.g. Alex Sharma">
                
                <label>Professional Summary</label>
                <textarea placeholder="Briefly describe your goals..."></textarea>
                
                <label>Key Skills</label>
                <input type="text" placeholder="e.g. Python, Public Speaking, Economics">
            </div>

            <h2>Experience</h2>
            <div class="input-group">
                <input type="text" placeholder="Job Title / Role">
                <input type="text" placeholder="Organization Name">
            </div>
            <button class="btn">Update Preview</button>
        </section>

        <section class="preview">
            <div class="resume-paper">
                <div class="header-preview">
                    <h1 id="name-display">Alex Sharma</h1>
                    <p>Student & Aspiring Professional</p>
                </div>
                
                <hr>

                <div class="content-preview">
                    <h3>Executive Summary</h3>
                    <p>Dedicated student with a background in leadership and event management, currently exploring the intersection of technology and social impact.</p>
                    
                    <h3>Core Competencies</h3>
                    <ul class="skills-list">
                        <li>Strategic Planning</li>
                        <li>Research & Analysis</li>
                        <li>Digital Communication</li>
                    </ul>
                </div>
            </div>
        </section>
    </main>

</body>
</html>
